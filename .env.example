# Server
CV2OFFER_HOST=127.0.0.1
CV2OFFER_PORT=8765
CV2OFFER_DB_PATH=server/db/cv2offer.sqlite

# LLM: first version uses DeepSeek for answer generation and text analysis.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ASR/TTS: first version uses Stepfun for speech recognition and text-to-speech.
ASR_PROVIDER=stepfun
TTS_PROVIDER=stepfun
STEPFUN_API_KEY=your_stepfun_api_key
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_ASR_MODEL=stepaudio-2.5-asr
STEPFUN_STREAM_ASR_MODEL=stepaudio-2.5-asr
STEPFUN_TTS_MODEL=stepaudio-2.5-tts
STEPFUN_TTS_VOICE=tianmeinvsheng

# Local paths
CONTEXT_DIR=context
OUTPUT_DIR=outputs
ACTIVE_JD_PATH=context/active_jd.md
ACTIVE_RESUME_PATH=context/active_resume.md
ACTIVE_QA_PATH=context/active_qa.md
ACTIVE_CONTEXT_PATH=context/active_context.json

# Optional runtime behavior
CV2OFFER_MOCK=1
CV2OFFER_DEV_RELOAD=true
CV2OFFER_LOG_LEVEL=info

# Live copilot audio capture
COPILOT_AUDIO_DEVICE=BlackHole
COPILOT_SEGMENT_SECONDS=8
COPILOT_SILENCE_RMS_THRESHOLD=80
